{
  "version": 3,
  "buildCommand": "pnpm run build:frontend",
  "installCommand": "pnpm install",
  "devCommand": "pnpm run dev",
  "outputDirectory": "dist/public",
  "env": {
    "NODE_ENV": "production"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
