{
  "version": 2,
  "buildCommand": "pnpm run build:frontend",
  "installCommand": "pnpm install",
  "outputDirectory": "dist/public",
  "env": {
    "NODE_ENV": "production",
    "SKIP_ENV_VALIDATION": "1"
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
