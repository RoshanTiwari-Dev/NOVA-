# Copy to .env.local for local dev. Add the same variables in Vercel → Project → Settings → Environment Variables.

# Database (use a hosted MySQL provider, e.g. PlanetScale, Railway, Aiven)
DATABASE_URL=mysql://user:password@host:3306/nova_db

# OAuth (configure redirect: https://your-domain.com/api/oauth/callback)
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=
OAUTH_SERVER_URL=

# Session
JWT_SECRET=

# Owner
OWNER_OPEN_ID=

# LLM API
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# Optional branding
VITE_APP_TITLE=Nova
VITE_APP_LOGO=
